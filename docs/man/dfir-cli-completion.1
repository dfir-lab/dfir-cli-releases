.TH "DFIR-CLI" "1" "Apr 2026" "DFIR Lab" "DFIR CLI Manual"

.SH NAME
dfir-cli-completion - Generate shell completion scripts


.SH SYNOPSIS
\fBdfir-cli completion [bash|zsh|fish|powershell] [flags]\fP


.SH DESCRIPTION
Generate shell completion scripts for dfir-cli.

.PP
To install completions:

.PP
bash:
    $ dfir-cli completion bash > /etc/bash_completion.d/dfir-cli

.PP
zsh:
    $ dfir-cli completion zsh > "${fpath[1]}/_dfir-cli"

.PP
fish:
    $ dfir-cli completion fish > ~/.config/fish/completions/dfir-cli.fish

.PP
powershell:
    PS> dfir-cli completion powershell | Out-String | Invoke-Expression


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for completion


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override API key for this invocation

.PP
\fB--api-url\fP=""
	Override API base URL (default from config)

.PP
\fB-j\fP, \fB--json\fP[=false]
	Shorthand for --output json

.PP
\fB--no-color\fP[=false]
	Disable colored output

.PP
\fB-o\fP, \fB--output\fP="table"
	Output format: table, json, jsonl, csv

.PP
\fB-p\fP, \fB--profile\fP="default"
	Named config profile

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	Minimal output

.PP
\fB--timeout\fP=1m0s
	HTTP request timeout

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	Show debug information (HTTP requests/responses)


.SH SEE ALSO
\fBdfir-cli(1)\fP
