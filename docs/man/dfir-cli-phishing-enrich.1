.TH "DFIR-CLI" "1" "Apr 2026" "DFIR Lab" "DFIR CLI Manual"

.SH NAME
dfir-cli-phishing-enrich - Enrich a URL with threat intelligence


.SH SYNOPSIS
\fBdfir-cli phishing enrich [flags]\fP


.SH DESCRIPTION
Enrich a URL with threat intelligence data including risk scoring,
categorization, and threat intel provider results.

.PP
Input methods:
  --url https://suspicious.example.com                       Enrich a single URL
  echo "https://suspicious.example.com" | dfir-cli phishing enrich   Pipe via stdin

.PP
Cost: 2 credits per request.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for enrich

.PP
\fB--url\fP=""
	URL to enrich with threat intelligence


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override API key for this invocation

.PP
\fB--api-url\fP=""
	Override API base URL (default from config)

.PP
\fB-j\fP, \fB--json\fP[=false]
	Shorthand for --output json

.PP
\fB--no-color\fP[=false]
	Disable colored output

.PP
\fB-o\fP, \fB--output\fP="table"
	Output format: table, json, jsonl, csv

.PP
\fB-p\fP, \fB--profile\fP="default"
	Named config profile

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	Minimal output

.PP
\fB--timeout\fP=1m0s
	HTTP request timeout

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	Show debug information (HTTP requests/responses)


.SH EXAMPLE
.EX
  dfir-cli phishing enrich --url https://suspicious.example.com
  echo "https://evil.com/phish" | dfir-cli phishing enrich
.EE


.SH SEE ALSO
\fBdfir-cli-phishing(1)\fP
