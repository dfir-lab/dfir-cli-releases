.TH "DFIR-CLI" "1" "Apr 2026" "DFIR Lab" "DFIR CLI Manual"

.SH NAME
dfir-cli-phishing-analyze - Analyze an email for phishing indicators


.SH SYNOPSIS
\fBdfir-cli phishing analyze [flags]\fP


.SH DESCRIPTION
Analyze a raw email, .eml file, or email headers for phishing indicators.

.PP
Input methods:
  --file suspicious.eml                         Read from an .eml file
  --raw "From: attacker@evil.com\\n..."          Inline raw email content
  cat email.eml | dfir-cli phishing analyze     Pipe via stdin

.PP
Use --ai for AI-enhanced analysis (costs 10 credits instead of 1).


.SH OPTIONS
\fB--ai\fP[=false]
	Use AI-enhanced analysis (10 credits)

.PP
\fB--file\fP=""
	Path to an .eml email file

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for analyze

.PP
\fB--raw\fP=""
	Raw email content as a string

.PP
\fB--type\fP=""
	Input type: headers, eml, raw (auto-detected if omitted)


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override API key for this invocation

.PP
\fB--api-url\fP=""
	Override API base URL (default from config)

.PP
\fB-j\fP, \fB--json\fP[=false]
	Shorthand for --output json

.PP
\fB--no-color\fP[=false]
	Disable colored output

.PP
\fB-o\fP, \fB--output\fP="table"
	Output format: table, json, jsonl, csv

.PP
\fB-p\fP, \fB--profile\fP="default"
	Named config profile

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	Minimal output

.PP
\fB--timeout\fP=1m0s
	HTTP request timeout

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	Show debug information (HTTP requests/responses)


.SH SEE ALSO
\fBdfir-cli-phishing(1)\fP
