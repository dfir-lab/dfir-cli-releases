.nh
.TH "DFIR-CLI" "1" "Apr 2026" "DFIR Lab" "DFIR CLI Manual"

.SH NAME
dfir-cli-phishing-safe-browsing - Check URLs against Google Safe Browsing


.SH SYNOPSIS
\fBdfir-cli phishing safe-browsing [flags]\fP


.SH DESCRIPTION
Check one or more URLs against the Google Safe Browsing database to determine
if they are associated with known threats such as malware, phishing, or
unwanted software.

.PP
Input methods:
  --url https://example.com                              Single URL check
  --batch urls.txt                                       File with one URL per line
  echo "https://example.com" | dfir-cli phishing safe-browsing   Pipe via stdin


.SH OPTIONS
\fB--batch\fP=""
	File with one URL per line (use - for stdin)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for safe-browsing

.PP
\fB--url\fP=""
	URL to check


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override API key for this invocation

.PP
\fB--api-url\fP=""
	Override API base URL (default from config)

.PP
\fB-j\fP, \fB--json\fP[=false]
	Shorthand for --output json

.PP
\fB--no-color\fP[=false]
	Disable colored output

.PP
\fB-o\fP, \fB--output\fP="table"
	Output format: table, json, jsonl, csv

.PP
\fB-p\fP, \fB--profile\fP="default"
	Named config profile

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	Minimal output

.PP
\fB--timeout\fP=1m0s
	HTTP request timeout

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	Show debug information (HTTP requests/responses)


.SH EXAMPLE
.EX
  dfir-cli phishing safe-browsing --url https://example.com
  dfir-cli phishing safe-browsing --batch urls.txt
  echo "https://example.com" | dfir-cli phishing safe-browsing
.EE


.SH SEE ALSO
\fBdfir-cli-phishing(1)\fP
