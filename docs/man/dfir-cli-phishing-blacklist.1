.TH "DFIR-CLI" "1" "Apr 2026" "DFIR Lab" "DFIR CLI Manual"

.SH NAME
dfir-cli-phishing-blacklist - Check IPs against DNS blacklists


.SH SYNOPSIS
\fBdfir-cli phishing blacklist [flags]\fP


.SH DESCRIPTION
Check one or more IP addresses against DNS blacklists (DNSBLs).

.PP
Input can be supplied via --ip for a single address, --batch for a file with
one IP per line, or piped via stdin.


.SH OPTIONS
\fB--batch\fP=""
	File with one IP per line (use - for stdin)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for blacklist

.PP
\fB--ip\fP=""
	Single IP address to check


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override API key for this invocation

.PP
\fB--api-url\fP=""
	Override API base URL (default from config)

.PP
\fB-j\fP, \fB--json\fP[=false]
	Shorthand for --output json

.PP
\fB--no-color\fP[=false]
	Disable colored output

.PP
\fB-o\fP, \fB--output\fP="table"
	Output format: table, json, jsonl, csv

.PP
\fB-p\fP, \fB--profile\fP="default"
	Named config profile

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	Minimal output

.PP
\fB--timeout\fP=1m0s
	HTTP request timeout

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	Show debug information (HTTP requests/responses)


.SH EXAMPLE
.EX
  dfir-cli phishing blacklist --ip 1.2.3.4
  dfir-cli phishing blacklist --batch ips.txt
  echo "1.2.3.4" | dfir-cli phishing blacklist
.EE


.SH SEE ALSO
\fBdfir-cli-phishing(1)\fP
