.TH "DFIR-CLI" "1" "Apr 2026" "DFIR Lab" "DFIR CLI Manual"

.SH NAME
dfir-cli-phishing-url-expand - Expand shortened URLs


.SH SYNOPSIS
\fBdfir-cli phishing url-expand [flags]\fP


.SH DESCRIPTION
Expand a shortened URL to reveal the final destination and redirect chain.

.PP
Input methods:
  --url https://bit.ly/abc123                                   Expand a single URL
  echo "https://bit.ly/abc123" | dfir-cli phishing url-expand   Pipe via stdin

.PP
Cost: 1 credit per request.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for url-expand

.PP
\fB--url\fP=""
	Shortened URL to expand


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--api-key\fP=""
	Override API key for this invocation

.PP
\fB--api-url\fP=""
	Override API base URL (default from config)

.PP
\fB-j\fP, \fB--json\fP[=false]
	Shorthand for --output json

.PP
\fB--no-color\fP[=false]
	Disable colored output

.PP
\fB-o\fP, \fB--output\fP="table"
	Output format: table, json, jsonl, csv

.PP
\fB-p\fP, \fB--profile\fP="default"
	Named config profile

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	Minimal output

.PP
\fB--timeout\fP=1m0s
	HTTP request timeout

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	Show debug information (HTTP requests/responses)


.SH EXAMPLE
.EX
  dfir-cli phishing url-expand --url https://bit.ly/abc123
  echo "https://t.co/xyz" | dfir-cli phishing url-expand
.EE


.SH SEE ALSO
\fBdfir-cli-phishing(1)\fP
